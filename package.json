{
  "name": "polymarket-asymmetry-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Railway-deployable Polymarket asymmetry bot MVP focused on safe public-data scoring.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "postinstall": "npm run build",
    "relayer:check": "node dist/scripts/relayerCheck.js"
  },
  "keywords": [
    "polymarket",
    "railway",
    "typescript",
    "trading-bot",
    "prediction-markets"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "ethers": "^6.16.0"
  }
}
