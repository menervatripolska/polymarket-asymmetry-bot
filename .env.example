NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
SCAN_INTERVAL_MS=300000
REQUEST_TIMEOUT_MS=12000
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_MARKETS_PATH=/markets
POLYMARKET_EVENTS_PATH=/events
POLYMARKET_MARKET_LIMIT=150
MIN_LIQUIDITY_USD=15000
MIN_VOLUME_24H_USD=2500
MAX_SPREAD_BPS=1200
MIN_DAYS_TO_CLOSE=1
MAX_DAYS_TO_CLOSE=45
MIN_NET_EDGE_BPS=150
FAMILY_SOFT_CAP=2
FAMILY_HARD_CAP=3
ENABLE_AUTO_SCAN=true

